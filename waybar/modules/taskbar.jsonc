{
  "wlr/taskbar": {
      "format": "{icon}",
      "rotate": 0,
      "icon-size": 19,
      "icon-theme": "Tela-circle-pink",
      "spacing": 0,
      "tooltip-format": "{title}",
      "on-click": "activate",
      "on-click-middle": "close",
      "ignore-list": [
          "Alacritty",
          "kitty"
      ]
  }
}
