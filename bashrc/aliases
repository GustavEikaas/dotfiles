_cpt_flags=(
  --allow-all-tools
  --deny-tool="shell(rm)"
  --deny-tool="shell(chmod)"
  --deny-tool="shell(git push)"
)

alias cpt='copilot "${_cpt_flags[@]}"'
alias cptr='copilot "${_cpt_flags[@]}" --resume'

alias kben='hyprctl keyword input:kb_layout us'
alias kbno='hyprctl keyword input:kb_layout no'

if ! pgrep -u "$USER" ssh-agent > /dev/null; then
    eval $(ssh-agent -s) > /dev/null
fi

ggp() {
  git pull "$@"
}

ggpm() {
  git pull origin main
}

ggu() {
  git reset --soft HEAD~
  git restore --staged .
}

gga() {
  git add "$@"
}

ggc() {
  git commit "$@"
}

ggs() {
  git status --porcelain -sb "$@"
}

ggch() {
  if [ "$#" -ge 1 ]; then
    git checkout "$@"
  else
    git fetch --all
    mapfile -t branches < <(git branch -r | grep -v 'HEAD' | sed 's/.*origin\///' | tr -d ' ')
    
    echo "Select a remote branch:"
    for i in "${!branches[@]}"; do
      echo "$((i+1)). ${branches[$i]}"
    done
    
    read -rp "Enter the number of the branch you want to select: " selection
    
    if [[ "$selection" =~ ^[0-9]+$ ]] && [ "$selection" -ge 1 ] && [ "$selection" -le "${#branches[@]}" ]; then
      local selectedBranch="${branches[$((selection-1))]}"
      git checkout "$selectedBranch"
    else
      echo "Invalid selection. Please enter a valid number."
    fi
  fi
}

ggr() {
  git reset --hard
  git clean -f -d
  local remoteTrackingBranch
  remoteTrackingBranch=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)

  if [ -n "$remoteTrackingBranch" ]; then
    ggp
  else
    echo "No remote tracking branch is set. Skipping pull."
  fi
}

ggrf() {
  local filePath="$1"
  local source="${2:-origin/main}"

  if [ -z "$filePath" ]; then
    echo "Error: filePath parameter is mandatory."
    return 1
  fi

  git restore "$filePath" --source="$source"
}

ggrm() {
  ggr
  local base currentBranch
  
  base=$(git branch --merged | sed 's/^[* ]*//' | grep -E '^(main|master|dev|develop|test)$' | head -n 1)
  currentBranch=$(git rev-parse --abbrev-ref HEAD)

  if [ -z "$base" ] && ! [[ "$currentBranch" =~ ^(main|master|dev|develop|test)$ ]]; then
    echo "Failed to find common ancestor [main,master,dev,develop,test]"
    return 1
  fi

  currentBranch=$(git rev-parse --abbrev-ref HEAD)

  if [ -n "$base" ] && [ "$base" != "$currentBranch" ]; then
    ggch "$base"
  fi

  ggp
}

ggpush() {
  local bypass=false
  local pass_args=()

  for arg in "$@"; do
    if [ "$arg" == "-F" ]; then
      bypass=true
    else
      pass_args+=("$arg")
    fi
  done

  local currentBranch
  currentBranch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

  if [ "$currentBranch" == "main" ] && [ "$bypass" = false ]; then
    echo "On main branch, use -F flag to bypass"
    return 1
  fi

  git push "${pass_args[@]}"
  git log -n 5 --oneline
}

ggac() {
  local text="$1"
  if [ -z "$text" ]; then
    echo "Error: Commit message required. Usage: ggac \"Your message here\""
    return 1
  fi
  ggs
  git add .
  git commit -m "$text"
}

ggd() {
  git diff "$@"
}

ask() {
    read -p "$1 (y/n): " resp
    case "$resp" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

main-check() {
    local current_branch=$(git rev-parse --abbrev-ref HEAD)
    [[ "$current_branch" == "main" ]]
}

ghprc() {
    gh pr create --draft --fill
    gh pr view
}

ghprm() {
    if ! gh pr merge --squash -d; then
        if ask "Pull Request still draft, mark as ready and merge?"; then
            gh pr ready
            gh pr merge --squash -d
        else
            echo "Aborting..."
            return 1
        fi
    fi
    ghprv
    if command -v ggrm >/dev/null; then ggrm; fi
}

ghpush() {
    local force_flag=false
    while getopts "F" opt; do
        case $opt in
            F) force_flag=true ;;
        esac
    done

    if main-check && [ "$force_flag" = false ]; then
        echo "On main branch, use -F flag to bypass"
        return 1
    fi

    git push

    if main-check; then
        git log -n 5 --oneline
        return 0
    fi

    if ! gh pr view >/dev/null 2>&1; then
        if ask "No PR linked to branch, do you want to create a draft PR?"; then
            ghprc
        fi
    fi

    git log -n 5 --oneline
}

ghprch() { gh pr checkout "$@"; }
ghprd()  { gh pr diff "$@"; }
ghprv()  { gh pr view "$@"; }
ghrv()   { gh repo view --web; }

ghprac() {
    local branch=$(git rev-parse --abbrev-ref HEAD)
    if [[ "$branch" =~ ^(main|master|dev)$ ]]; then
        echo "You are on a protected branch ($branch). Switch to a feature branch."
        return 1
    fi

    git add .
    git commit -m "$*" || { echo "Commit failed. Aborting..."; return 1; }
    git push || { echo "Push failed. Aborting..."; return 1; }

    gh pr create --fill
    gh pr view
}

